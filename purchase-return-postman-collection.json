{
	"info": {
		"_postman_id": "purchase-return-collection",
		"name": "Purchase Return",
		"description": "Purchase Return API endpoints for handling returns of items after invoice settlement (defect/broken/spoilt items).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Get Purchase Returns (Sync)",
			"request": {
				"auth": {
					"type": "noauth"
				},
				"method": "GET",
				"header": [
					{
						"key": "token",
						"value": "{{userToken}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{basedUrl}}/purchaseReturn/sync?outletId=1&skip=0&take=50",
					"host": [
						"{{basedUrl}}"
					],
					"path": [
						"purchaseReturn",
						"sync"
					],
					"query": [
						{
							"key": "outletId",
							"value": "1",
							"description": "(Required) Filter by outlet ID"
						},
						{
							"key": "skip",
							"value": "0",
							"description": "Pagination offset (default: 0)"
						},
						{
							"key": "take",
							"value": "50",
							"description": "Number of records to return (default: 100)"
						},
						{
							"key": "lastSyncTimestamp",
							"value": "2025-01-01T00:00:00.000Z",
							"description": "ISO timestamp for delta sync",
							"disabled": true
						}
					]
				},
				"description": "Get all purchase returns with delta sync support."
			},
			"response": []
		},
		{
			"name": "Get Purchase Returns (Date Range)",
			"request": {
				"auth": {
					"type": "noauth"
				},
				"method": "GET",
				"header": [
					{
						"key": "token",
						"value": "{{userToken}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{basedUrl}}/purchaseReturn/dateRange?outletId=1&startDate=2025-01-01&endDate=2025-12-31&skip=0&take=50",
					"host": [
						"{{basedUrl}}"
					],
					"path": [
						"purchaseReturn",
						"dateRange"
					],
					"query": [
						{
							"key": "outletId",
							"value": "1",
							"description": "(Required) Filter by outlet ID"
						},
						{
							"key": "startDate",
							"value": "2025-01-01",
							"description": "(Required) Start date (ISO format)"
						},
						{
							"key": "endDate",
							"value": "2025-12-31",
							"description": "(Required) End date (ISO format)"
						},
						{
							"key": "skip",
							"value": "0",
							"description": "Pagination offset"
						},
						{
							"key": "take",
							"value": "50",
							"description": "Number of records to return"
						},
						{
							"key": "lastSyncTimestamp",
							"value": "2025-01-01T00:00:00.000Z",
							"description": "ISO timestamp for delta sync",
							"disabled": true
						}
					]
				},
				"description": "Get purchase returns within a specific date range."
			},
			"response": []
		},
		{
			"name": "Get Purchase Returns By Invoice",
			"request": {
				"auth": {
					"type": "noauth"
				},
				"method": "GET",
				"header": [
					{
						"key": "token",
						"value": "{{userToken}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{basedUrl}}/purchaseReturn/byInvoice/1",
					"host": [
						"{{basedUrl}}"
					],
					"path": [
						"purchaseReturn",
						"byInvoice",
						"1"
					]
				},
				"description": "Get all purchase returns for a specific invoice. Replace '1' with the actual invoice ID."
			},
			"response": []
		},
		{
			"name": "Get Purchase Return By ID",
			"request": {
				"auth": {
					"type": "noauth"
				},
				"method": "GET",
				"header": [
					{
						"key": "token",
						"value": "{{userToken}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{basedUrl}}/purchaseReturn/1",
					"host": [
						"{{basedUrl}}"
					],
					"path": [
						"purchaseReturn",
						"1"
					]
				},
				"description": "Get a single purchase return by ID with full details. Replace '1' with the actual return ID."
			},
			"response": []
		},
		{
			"name": "Create Purchase Return",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "token",
						"value": "{{userToken}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"purchaseReturns\": [\n    {\n      \"returnNumber\": \"RTN-2025-0001\",\n      \"invoiceId\": 1,\n      \"outletId\": 1,\n      \"supplierId\": 1,\n      \"returnDate\": \"2025-01-23\",\n      \"remark\": \"Quality issues found during inspection\",\n      \"performedBy\": \"warehouse@example.com\",\n      \"purchaseReturnItems\": [\n        {\n          \"itemId\": 1,\n          \"itemVariantId\": null,\n          \"quantity\": 3,\n          \"unitPrice\": 100,\n          \"returnReason\": \"DEFECT\",\n          \"remark\": \"Manufacturing defect in batch\"\n        },\n        {\n          \"itemId\": 2,\n          \"itemVariantId\": null,\n          \"quantity\": 2,\n          \"unitPrice\": 150,\n          \"returnReason\": \"SPOILT\",\n          \"remark\": \"Expired before delivery\"\n        }\n      ]\n    }\n  ]\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{basedUrl}}/purchaseReturn/create",
					"host": [
						"{{basedUrl}}"
					],
					"path": [
						"purchaseReturn",
						"create"
					]
				},
				"description": "Create a new purchase return. Stock is automatically adjusted upon creation.\n\n**Return Reasons:**\n- DEFECT: Manufacturing defect\n- SPOILT: Expired or spoiled\n- BROKEN: Damaged during delivery or storage\n- WRONG_ITEM: Supplier delivered incorrect item\n- OTHER: Other reason (remark required)"
			},
			"response": []
		},
		{
			"name": "Update Purchase Return",
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "token",
						"value": "{{userToken}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"id\": 1,\n  \"returnNumber\": \"RTN-2025-0001\",\n  \"remark\": \"Updated remark with additional details\",\n  \"performedBy\": \"updated_user@example.com\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{basedUrl}}/purchaseReturn/update",
					"host": [
						"{{basedUrl}}"
					],
					"path": [
						"purchaseReturn",
						"update"
					]
				},
				"description": "Update a purchase return. Only remark and performedBy can be updated after creation."
			},
			"response": []
		},
		{
			"name": "Delete Purchase Return",
			"request": {
				"method": "DELETE",
				"header": [
					{
						"key": "token",
						"value": "{{userToken}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{basedUrl}}/purchaseReturn/1",
					"host": [
						"{{basedUrl}}"
					],
					"path": [
						"purchaseReturn",
						"1"
					]
				},
				"description": "Cancel/delete a purchase return. This reverses the stock operations (restores stock levels). Replace '1' with the actual return ID."
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "basedUrl",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "userToken",
			"value": "your-auth-token-here",
			"type": "string"
		}
	]
}
